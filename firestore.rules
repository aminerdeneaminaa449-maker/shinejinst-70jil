rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Хэрэглэгчийн профайл: өөрийнхөө мэдээллийг үүсгэж/уншиж болно.
    // Админ бол БҮХ хэрэглэгчийн мэдээллийг уншиж болно.
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow get:    if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list:   if isAdmin();
      allow delete: if isAdmin();
    }

    // Санал хүсэлт: нэвтэрсэн хэн ч бичиж болно, зөвхон админ уншина/жагсаана.
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Гавьяат хүмүүс: сайт дээр бүгд харна (public), зөвхон админ нэмж/устгаж болно.
    match /honorees/{honoreeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Админуудын жагсаалт: зөвхон Firebase Console-оос гараар нэмнэ/хасна.
    // (аюулгүй байдлын үүднээс апп дотроос бичих боломжгүй)
    match /admins/{adminId} {
      allow get: if request.auth != null && request.auth.uid == adminId;
      allow list: if isAdmin();
      allow write: if false;
    }
  }
}
